# App
APP_NAME=vernon_store_analytics
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# Database (PostgreSQL 17)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/vernon_store_analytics_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# CCTV / Video Stream
CCTV_STREAM_URLS=[]
CCTV_FRAME_INTERVAL=5

# Shoplifting Detection
SHOPLIFTING_THRESHOLD=0.75
SHOPLIFTING_NOTIFICATION_COOLDOWN_SECONDS=300

# Notification
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_EMAIL_TO=
