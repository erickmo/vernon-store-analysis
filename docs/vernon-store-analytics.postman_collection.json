          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/analytics/shoplifting?period=week&store_id={{store_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "analytics", "shoplifting"],
              "query": [
                {
                  "key": "period",
