                  "description": "day, week, month, year"
                },
                {
                  "key": "store_id",
                  "value": "{{store_id}}"
                },
                {
                  "key": "date_from",
                  "value": "2026-03-10",
                  "disabled": true,
                  "description": "Start date (YYYY-MM-DD)"
                },
                {
                  "key": "date_to",
                  "value": "2026-03-17",
                  "disabled": true,
                  "description": "End date (YYYY-MM-DD)"
                }
              ]
            }
          },
          "response": []
